{
  "name": "cyia-web-template",
  "version": "1.0.0",
  "scripts": {
    "init": "npm run build:dev -w define && npm run init -w server",
    "build:dev": "npm run build:dev -ws --if-present",
    "build:define:watch": "npm run build:watch -w define",
    "start": "concurrently \"npm run start -w define\" \"npm run build:dev -w server\" \"npm run start -w website\" ",
    "lint": "eslint --fix ./server && prettier ./server --write && eslint --fix ./website && prettier ./website --write && eslint --fix ./define && prettier ./define --write && eslint --fix ./desktop && prettier ./desktop --write && eslint --fix ./mobile && prettier ./mobile --write && eslint --fix ./web-common && prettier ./web-common --write",
    "test:mcp": "npx @modelcontextprotocol/inspector",
    "build:website:prod": "npm run build -w define && npm run build -w website",
    "build:server:prod": "npm run build -w define && npm run build -w server",
    "build": "tsx ./script/docker-build.ts"
  },
  "workspaces": [
    "./define",
    "./server",
    "./website"
  ],
  "author": "",
  "license": "ISC",
  "description": "",
