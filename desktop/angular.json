{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "schematicCollections": ["@angular-eslint/schematics"]
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "angular-electron": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "schematics": {
        "@schematics/angular:application": {
          "strict": true
        },
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "./dist/webview",
              "browser": ""
            },
            "index": "src/index.html",
            "tsConfig": "src/tsconfig.app.json",
            "polyfills": [],
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/assets",
              {
                "glob": "**/*",
                "input": "i18n-assets",
                "output": "assets/i18n"
              },
              {
                "glob": "**/*",
                "input": "./node_modules/@web-common/raw/assets",
                "output": "assets"
              },
              {
                "input": "./node_modules/onnxruntime-web/dist",
                "output": ".",
                "glob": "ort-wasm-simd-threaded.{wasm,mjs}"
              },
              {
                "input": "./node_modules/@ricky0123/vad-web/dist",
                "output": ".",
                "glob": "silero_vad_v5.onnx"
              },
              {
                "input": "./node_modules/@ricky0123/vad-web/dist",
                "output": ".",
                "glob": "vad.worklet.bundle.min.js"
              },
              {
                "input": "node_modules/@electric-sql/pglite/dist",
                "glob": "{pglite,initdb}.wasm"
              },
              {
                "input": "node_modules/@electric-sql/pglite/dist",
                "glob": "pglite.data"
              }
            ],
            "styles": [
              "src/styles.css",
              "material-icons/iconfont/filled.css",
              "./node_modules/@web-common/raw/style.css"
            ],
            "scripts": [],
            "browser": "src/main.ts",
            "webWorkerTsConfig": "tsconfig.worker.json",
            "define": {
              "process.env.WORK_PLATFORM": "'client'",
              "process.env.NODE_ENV": "'dev'",
              "process.platform": "'browser'"
            }
          },
          "configurations": {
            "dev": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true,
              "namedChunks": false,
              "aot": false,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev.ts"
                }
              ]
            },
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "define": {
                "process.env.WORK_PLATFORM": "'client'",
                "process.env.NODE_ENV": "'production'",
                "process.platform": "'browser'"
              },
              "baseHref": "./"
            },
            "web": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true,
              "namedChunks": false,
              "aot": false,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.web.ts"
                }
              ]
            },
            "web-production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.web.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "angular-electron:build"
          },
          "configurations": {
            "dev": {
              "buildTarget": "angular-electron:build:dev",
              "prebundle": false
            },
            "production": {
              "buildTarget": "angular-electron:build:production",
              "prebundle": false
            },
            "web": {
              "buildTarget": "angular-electron:build:web",
              "prebundle": false
            },
            "web-production": {
              "buildTarget": "angular-electron:build:web-production",
              "prebundle": false
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "angular-electron:build"
          }
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "polyfills": [],
            "tsConfig": "src/tsconfig.spec.json",
            "globalMocks": ["styleTransform", "matchMedia", "getComputedStyle"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
      }
    },
    "angular-electron-e2e": {
      "root": "e2e",
      "projectType": "application",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["e2e/**/*.ts"]
          }
        }
      }
    }
  },
  "schematics": {
    "@angular-eslint/schematics:application": {
      "setParserOptionsProject": true
    },
    "@angular-eslint/schematics:library": {
      "setParserOptionsProject": true
    },
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
