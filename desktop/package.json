{
  "name": "audio-asr",
  "keywords": [],
  "main": "dist/main.mjs",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "electron-rebuild": "electron-rebuild -f",
    "ng": "ng",
    "start": "npm-run-all -p electron:serve ng:serve",
    "ng:serve": "ng serve -c web",
    "build:main": "tsx ./script/build.ts",
    "build": "npm run build:main && ng build --base-href ./",
    "build:dev": "npm run build -- -c dev",
    "build:prod": "npm run build -- -c production",
    "web:build": "npm run build -- -c web-production",
    "electron": "electron",
    "electron:serve-tsc": "tsx ./script/build.ts --watch",
    "electron:serve": "wait-on tcp:4200 && chcp.com 65001 && npm run electron:serve-tsc",
    "electron:local": "npm run build:dev && electron .",
    "electron:build": "rimraf ./dist && npm run build:main -- --prod && ng build -c production && tsx ./script/electron-build.ts",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "e2e": "npm run build:prod && playwright test -c e2e/playwright.config.ts e2e/",
    "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "lint": "ng lint --fix && prettier ./src --write && prettier ./app --write",
    "init": "tsx ./script/init.build.ts && node ./init-dist/init.mjs",
    "update": "ng update @angular/core@21 @angular/cdk@21 @angular/material@21 @angular/cli@21 --force --allow-dirty",
    "build:patch": "tsc -P ./script/patch"
  },
  "dependencies": {
    "@cyia/dl": "1.5.1",
    "@cyia/external-call": "1.5.1",
    "@cyia/zip": "1.5.1",
    "@electron/rebuild": "4.0.3",
    "@ricky0123/vad-web": "0.0.30",
    "electron-store": "11.0.2",
    "electron-trpc-experimental": "1.0.0-alpha.1",
    "file-type": "^22.0.1",
    "normalize-path": "3.0.0",
    "onnxruntime-web": "1.24.3",
    "rfdc": "1.4.1",
    "srt-parser-2": "^1.2.3",
    "static-injector": "6.3.1",
    "tslib": "2.8.1",
    "uuid": "13.0.0",
    "@web-common/raw": "workspace:*"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@ngx-translate/core": "16.0.4",
    "@ngx-translate/http-loader": "16.0.1",
    "@playwright/test": "1.52.0",
    "@types/audioworklet": "0.0.86",
    "@types/jest": "29.5.14",
    "@types/node": "^24.0.0",
    "@types/normalize-path": "^3.0.2",
    "@typescript-eslint/eslint-plugin": "8.45.0",
    "@typescript-eslint/parser": "8.45.0",
    "conventional-changelog-cli": "4.1.0",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "electron-debug": "4.1.0",
    "electron-reloader": "1.2.3",
    "eslint": "9.36.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "50.7.1",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-unused-imports": "4.2.0",
    "globals": "16.4.0",
    "jest": "29.7.0",
    "npm-run-all": "4.1.5",
    "playwright": "1.52.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.45.0",
    "wait-on": "9.0.5",
    "webdriver-manager": "12.1.9"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "browserslist": [
    "chrome 137"
  ],
  "overrides": {
    "@electron/rebuild": {
      "node-abi": "^4.28.0"
    }
  },
  "peerDependencies": {
    "@electric-sql/pglite": ">=0.1.0",
    "@piying-lib/angular-core": ">=0.1.0",
    "@piying-lib/angular-daisyui": ">=0.1.0",
    "tslib": ">=0.1.0",
    "@angular/animations": ">=0.1.0",
    "@angular/cdk": ">=0.1.0",
    "@angular/common": ">=0.1.0",
    "@angular/compiler": ">=0.1.0",
    "@angular/core": ">=0.1.0",
    "@angular/forms": ">=0.1.0",
    "@angular/material": ">=0.1.0",
    "@angular/platform-browser": ">=0.1.0",
    "@angular/platform-browser-dynamic": ">=0.1.0",
    "@angular/router": ">=0.1.0",
    "@angular/build": ">=0.1.0",
    "@angular/cli": ">=0.1.0",
    "@angular/compiler-cli": ">=0.1.0",
    "@angular/language-service": ">=0.1.0"
  }
}
