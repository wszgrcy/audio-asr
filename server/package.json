{
  "name": "server",
  "version": "1.0.0",
  "scripts": {
    "build": "tsx ./script/build.ts --prod",
    "build:dev": "tsx ./script/build.ts --watch",
    "start": "npm run build:dev",
    "init": "tsx --env-file=.env.init-dev ./script/init.dev.ts",
    "test:pg": "tsx --env-file=.env --inspect ./script/pg/test.ts",
    "test": "rimraf -g ./test-dist && tsx ./script/test.esbuild.ts && mocha \"./test-dist/**/*.spec.mjs\" --enable-source-maps --inspect",
    "coverage": "c8 npm run test",
    "open:doc": "npx openapi-typescript ./docs/swagger/api.json -o ../website/src/app/openapi/type.d.ts",
    "build:type": "rimraf ./type-dist && tsc -p ./tsconfig.type.json && cpx ./src/sdk/package.json ./type-dist",
    "publish:type": "npm run build:type && npm --registry=http://lan-server.chloc:5555 publish ./type-dist/"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "9.6.1",
    "fastify": "^5.8.2",
    "pino-pretty": "^13.0.0",
    "static-injector": "^6.3.1",
    "tslib": "^2.3.0",
    "@project/define": "workspace:*",
    "pg": "8.20.0",
    "openai": "6.32.0",
    "fastq": "1.20.1",
    "lru-cache": "11.2.5",
    "axios": "1.13.4",
    "uuid": "13.0.0",
    "@fastify/websocket": "11.2.0",
    "node-wav": "0.0.2"
  },
  "devDependencies": {
    "@types/node-wav": "0.0.4",
    "@types/pg": "8.16.0",
    "@types/node": "^24.0.3",
    "auth": "1.5.6",
    "normalize-path": "3.0.0",
    "@types/normalize-path": "^3.0.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "fast-glob": "^3.3.3",
    "mocha": "^11.7.5",
    "openapi-typescript": "7.10.1",
    "undici-types": "7.16.0"
  }
}
